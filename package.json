{
	"name": "@rasmuslp/eslint-config",
	"version": "10.1.2",
	"description": "My configs",
	"homepage": "https://github.com/rasmuslp/eslint-config-rasmuslp#readme",
	"bugs": {
		"url": "https://github.com/rasmuslp/eslint-config-rasmuslp/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rasmuslp/eslint-config-rasmuslp.git"
	},
	"license": "BSD-3-Clause",
	"author": {
		"name": "Rasmus Ljungmann Pedersen",
		"email": "rasmuslp@gmail.com"
	},
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.d.ts",
			"import": "./src/index.js"
		}
	},
	"files": [
		"src/"
	],
	"scripts": {
		"build:types": "tsc -p tsconfig.build.json",
		"config-inspector": "npx @eslint/config-inspector@latest",
		"format": "npm run prettier:write",
		"full-suite": "npm run format && npm run lint && npm run build:types",
		"lint": "eslint .",
		"prepare": "husky",
		"prepublishOnly": "npm run build:types",
		"prettier:check": "prettier . --check",
		"prettier:write": "prettier . --write"
	},
	"dependencies": {
		"@eslint/js": "^9.39.4",
		"eslint-config-flat-gitignore": "^2.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.5",
		"eslint-plugin-import-x": "^4.17.1",
		"eslint-plugin-promise": "^7.3.0",
		"eslint-plugin-unicorn": "^65.0.1",
		"typescript-eslint": "^8.63.0"
	},
	"devDependencies": {
		"@commitlint/cli": "21.2.0",
		"@commitlint/config-conventional": "21.2.0",
		"eslint": "9.39.4",
		"eslint-plugin-jest": "29.15.4",
		"eslint-plugin-n": "18.2.1",
		"husky": "9.1.7",
		"prettier": "3.9.4",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"eslint": ">=9.39.4",
		"eslint-plugin-jest": ">=29.15.2",
		"eslint-plugin-n": ">=18.0.1",
		"typescript": ">=5.9.3"
	},
	"peerDependenciesMeta": {
		"eslint-plugin-jest": {
			"optional": true
		},
		"eslint-plugin-n": {
			"optional": true
		}
	},
	"engines": {
		"node": ">=22.13.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
